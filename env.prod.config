# Production Environment Configuration
# Rename this file to .env.prod after copying
# IMPORTANT: Change all passwords and secrets before using in production!

NODE_ENV=production
APP_PORT=5900
PORT=5900

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=splitbuddy_user_prod
DB_PASSWORD=SplitBuddy2024!Secure!Prod
DB_NAME=splitbuddy_prod
DB_DATABASE=splitbuddy_prod

# JWT Configuration - CHANGE THIS IN PRODUCTION!
JWT_SECRET=prod-jwt-secret-CHANGE-THIS-TO-SECURE-RANDOM-STRING

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# SMTP Configuration - SET YOUR PRODUCTION EMAIL
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-production-email@gmail.com
SMTP_PASS=your-production-app-password
SMTP_FROM=your-production-email@gmail.com

# Google OAuth Configuration - SET YOUR PRODUCTION OAUTH
GOOGLE_CLIENT_ID=your-production-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-production-client-secret
GOOGLE_ANDROID_CLIENT_ID=your-production-android-client-id.apps.googleusercontent.com
GOOGLE_CALLBACK_URL=https://your-production-domain.com/api/v1/auth/google/callback

# CORS Configuration - SET YOUR FRONTEND URL
CORS_ORIGIN=https://your-frontend-domain.com

# Queue Configuration
EMAIL_QUEUE_NAME=email-queue
NOTIFICATION_QUEUE_NAME=notification-queue